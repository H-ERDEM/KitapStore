@model List<ProductBook>

<div class="card card-body my-3">
    <form asp-action="Index" method="get">
        <div class="container">
            <div class="row">
                <div class="col-md-10">
                    <select name="category" class="form-select" asp-items="ViewBag.Categories">
                        <option value="0">Hepsi</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-success">Filtrele</button>
                </div>
            </div>
        </div>
    </form>
</div>

<div class="row container">
    @foreach (var book in Model)
    {
        <div class="col-md-3 mb-2" style="width: 18rem;">
            <div class="card">
                <img src="@book.Image" alt="" class="card-img-top img-fluid" style="height: 200px; object-fit: contain;">
                <div class="card-body">
                    <h5 class="card-title">@book.BookName</h5>
                    <p class="card-text"> Sayfa : @book.PageCount</p>
                    <a href="/Home/Details/@book.BookId" class="btn btn-primary">Detay</a>
                </div>
            </div>
        </div>
    }
</div>
